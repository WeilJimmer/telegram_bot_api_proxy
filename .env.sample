# Telegram
BOT_TOKEN=your_bot_token_here
TELEGRAM_API_BASE=https://api.telegram.org

# Proxy Auth
# 空字串可關閉驗證
API_KEY=your_proxy_api_key_here

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=15820

# Access Control (JSON 字串)
ALLOWED_CHAT_IDS=["*"]
ALLOWED_METHODS={"*":["*"]}
GLOBAL_ALLOWED_METHODS=["getMe"]
